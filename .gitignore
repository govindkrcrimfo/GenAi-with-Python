# macOS system files generated by Finder (not related to project code)
.DS_Store

# VS Code editor settings (personal IDE configuration, not needed in Git)
.vscode/

# Temporary file created when running code in VS Code
tempCodeRunnerFile.py

# Python virtual environment (contains installed dependencies locally)
venv/
.venv/

# Python compiled bytecode cache (auto-generated for performance)
__pycache__/

# Compiled Python files (auto-generated, not human-written code)
*.pyc

# Environment variables file (stores API keys and secrets, must NOT be exposed)
.env

# Log files generated during runtime/debugging (not source code)
*.log

# ChromaDB vector database storage (auto-generated embeddings and indexes)
chroma_storage/

# Jupyter notebook checkpoints (auto-saved backup files, not needed in Git)
.ipynb_checkpoints/

# HuggingFace cache (downloads of models stored locally, large and auto-generated)
.cache/